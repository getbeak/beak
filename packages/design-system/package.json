{
	"name": "@beak/design-system",
	"version": "0.0.0",
	"private": true,
	"main": "dist/index",
	"types": "dist/index",
	"files": [
		"dist"
	],
	"type": "module",
	"scripts": {
		"build": "pnpm clean && pnpm compile",
		"clean": "rm -rf ./dist && rm -rf tsconfig.tsbuildinfo",
		"compile": "tsgo --build tsconfig.json",
		"typecheck": "tsgo",
		"lint": "biome lint .",
		"start": "tsgo --build tsconfig.json --watch"
	},
	"dependencies": {
		"@chakra-ui/react": "^3.35.0",
		"@emotion/react": "^11.14.0",
		"framer-motion": "^11.18.2",
		"next-themes": "^0.4.6"
	}
}
