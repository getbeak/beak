{
	"name": "@beak/requester-node",
	"version": "0.0.0",
	"private": true,
	"main": "dist/index",
	"types": "dist/index",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm clean && pnpm compile",
		"clean": "rm -rf ./dist && rm -rf tsconfig.tsbuildinfo",
