		"typecheck": "tsgo",
		"lint": "biome lint .",
		"start": "tsgo --build tsconfig.json --watch"
	},
	"dependencies": {
		"@beak/common": "*",
		"@getbeak/types": "^2.1.0",
		"node-fetch": "^3.3.2"
	},
	"devDependencies": {
		"@types/node-fetch": "^2.6.13"
	}
}
