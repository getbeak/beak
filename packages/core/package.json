{
	"name": "@beak/core",
	"version": "0.0.0",
	"private": true,
	"main": "dist/index",
	"types": "dist/index",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm clean && pnpm compile",
		"clean": "rm -rf ./dist && rm -rf tsconfig.tsbuildinfo",
		"compile": "tsgo --build tsconfig.json",
		"typecheck": "tsgo",
		"start": "tsgo --build tsconfig.json --watch",
		"lint": "biome lint .",
		"test": "vitest",
		"test:run": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage --passWithNoTests",
		"test:ui": "vitest --ui",
		"schemas:gen": "tsx scripts/generate-json-schemas.ts"
	},
	"dependencies": {
		"@beak/common": "*",
		"@beak/ksuid": "*",
		"@beak/squawk": "*",
		"@getbeak/types": "^1.0.0",
		"@reduxjs/toolkit": "^2.11.2",
		"zod": "^4.4.3",
		"zod-to-json-schema": "^3.25.2"
	},
	"devDependencies": {
		"vitest": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6"
	}
}
