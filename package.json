{
	"name": "beak",
	"description": "A feathery cross-platform API crafting tool",
	"private": true,
	"author": {
		"name": "Alexander Forbes-Reed (0xdeafcafe)",
		"email": "info@getbeak.app"
	},
	"homepage": "https://getbeak.app",
	"engines": {
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@10.15.1",
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"build:apps-host": "pnpm --filter '@beak/apps-host-*...' build",
		"build:apps-host-electron": "pnpm --filter '@beak/apps-host-electron...' build",
		"build:apps-host-web": "pnpm --filter '@beak/apps-host-web...' build",
		"build:apps-web": "pnpm --filter '@beak/apps-web-*...' build",
		"build:apps-web-marketing": "pnpm --filter '@beak/apps-web-marketing...' build",
		"build:apps-web-share": "pnpm --filter '@beak/apps-web-share...' build",
		"prepackage": "pnpm build:apps-host",
		"prepackage:release": "pnpm build:apps-host",
		"package": "pnpm --filter @beak/apps-host-electron package",
		"package:release": "pnpm --filter @beak/apps-host-electron package:release",
		"start:electron-host-screenshot": "cross-env SCREENSHOT_SIZING=true pnpm --parallel --filter '@beak/apps-host-electron' --filter '@beak/ui' start",
		"start:apps-host-electron": "pnpm --parallel --filter '@beak/apps-host-electron' --filter '@beak/ui' start",
		"start:apps-host-web": "pnpm --filter '@beak/apps-host-web' start",
		"start:apps-web-marketing": "pnpm --filter '@beak/apps-web-marketing' start",
		"start:apps-web-share": "pnpm --filter '@beak/apps-web-share' start",
		"dev:apps-web-marketing": "pnpm --filter '@beak/apps-web-marketing' dev",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"typecheck": "pnpm -r typecheck",
		"typecheck:apps-host": "pnpm --filter '@beak/apps-host-*...' typecheck",
		"unfuck": "pnpm -r exec rm -rf node_modules && rm -rf node_modules && pnpm install",
		"release-safety": "pnpm typecheck && pnpm lint && pnpm build",
		"safety:dev": "pnpm typecheck && pnpm -r test:run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:install": "playwright install --with-deps chromium"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3"
		},
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@sentry/cli",
			"core-js",
			"core-js-pure",
			"electron",
			"electron-builder",
			"esbuild",
			"keytar",
			"vm2"
		],
		"patchedDependencies": {
			"electron-esbuild@10.0.0": "patches/electron-esbuild@10.0.0.patch",
			"postcss@8.5.14": "patches/postcss@8.5.14.patch",
			"vite-plugin-monaco-editor": "patches/vite-plugin-monaco-editor.patch",
			"monaco-editor@0.55.1": "patches/monaco-editor@0.55.1.patch"
		}
	},
	"devDependencies": {
		"@0xdeafcafe/tslsp-cli": "^0.6.0",
		"@biomejs/biome": "^2.4.15",
		"@playwright/test": "^1.60.0",
		"@types/node": "^25.7.0",
		"@typescript/native-preview": "^7.0.0-dev.20260608.1",
		"cross-env": "^7.0.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
