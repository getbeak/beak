{
	"compilerOptions": {
		"composite": true,
		"incremental": true,
		"rootDir": ".",
		"outDir": "./dist",

		"declaration": true,
		"strict": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"target": "ES2018",
		"moduleResolution": "bundler",
		"module": "esnext",
		"allowSyntheticDefaultImports": true,

		"typeRoots": ["./node_modules/@types"],

		"paths": {
			"@beak/apps-host-electron": ["./apps-host/electron/src"],
			"@beak/apps-host-electron/*": ["./apps-host/electron/src/*"],

			"@beak/apps-host-web": ["./apps-host/web/src"],
			"@beak/apps-host-web/*": ["./apps-host/web/src/*"],

			"@beak/apps-web-marketing": ["./apps-web/marketing/src"],
			"@beak/apps-web-marketing/*": ["./apps-web/marketing/src/*"],

			"@beak/apps-web-share": ["./apps-web/share/src"],
			"@beak/apps-web-share/*": ["./apps-web/share/src/*"],

			"@beak/ui": ["./packages/ui/src"],
			"@beak/ui/*": ["./packages/ui/src/*"],

			"@beak/common": ["./packages/common/src"],
			"@beak/common/*": ["./packages/common/src/*"],

			"@beak/common-host": ["./packages/common-host/src"],
			"@beak/common-host/*": ["./packages/common-host/src/*"],

			"@beak/core": ["./packages/core/src"],
			"@beak/core/*": ["./packages/core/src/*"],

			"@beak/design-system": ["./packages/design-system/src"],
			"@beak/design-system/*": ["./packages/design-system/src/*"],

			"@beak/json-client": ["./packages/json-client/src"],
			"@beak/json-client/*": ["./packages/json-client/src/*"],

			"@beak/ksuid": ["./packages/ksuid/src"],
			"@beak/ksuid/*": ["./packages/ksuid/src/*"],

			"@beak/realtime-values": ["./packages/realtime-values/src"],
			"@beak/realtime-values/*": ["./packages/realtime-values/src/*"],

			"@beak/requester-node": ["./packages/requester-node/src"],
			"@beak/requester-node/*": ["./packages/requester-node/src/*"],

			"@beak/squawk": ["./packages/squawk/src"],
			"@beak/squawk/*": ["./packages/squawk/src/*"],

			"@getbeak/types": ["./packages/types/src"],
			"@getbeak/types/*": ["./packages/types/src/*"],

			"@getbeak/types-realtime-value": ["./packages/types-realtime-value/src"],
			"@getbeak/types-realtime-value/*": ["./packages/types-realtime-value/src/*"],

			"@getbeak/types-variables": ["./packages/types-variables"],
			"@getbeak/types-variables/*": ["./packages/types-variables/*"]
		}
	},
	"exclude": ["node_modules", "dist"]
}
