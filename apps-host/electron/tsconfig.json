{
	"extends": "./../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist-ts",
		"composite": true,

		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"module": "es2022",
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true
	},
	"references": [
		{
			"path": "../../packages/common"
		},
		{
			"path": "../../packages/runtime-shared"
		},
		{
			"path": "../../packages/ksuid"
		},
		{
			"path": "../../packages/requester-node"
		}
	],
	"exclude": [
		"node_modules",
		"eslint.config.js",
		"dist",
		"dist-ts",
		"dist-react",
		"dist-electron",
		"../app",
		"../common",
		"../requester-node"
	]
}
