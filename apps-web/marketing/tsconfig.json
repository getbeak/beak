{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"paths": {
			"@beak/apps-web-marketing/*": ["./src/*"]
		}
	},
	"include": [".astro/types.d.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.astro"],
	"exclude": ["node_modules", "dist", "dist-ts", ".astro"]
}
