{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.js",
			"**/*.jsx",
			"**/*.json",
			"!**/node_modules",
			"!**/dist",
			"!**/dist-electron",
			"!**/dist-react",
			"!**/build",
			"!**/.astro",
			"!**/coverage",
			"!pnpm-lock.yaml",
			"!**/tsconfig.tsbuildinfo"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 1,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all",
			"bracketSpacing": true,
			"arrowParentheses": "asNeeded",
			"quoteProperties": "asNeeded"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"trailingCommas": "none"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"useExhaustiveDependencies": "off",
				"noUnusedVariables": {
					"level": "error",
					"options": {
						"ignoreRestSiblings": true
					}
				}
			},
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "error",
				"useTemplate": "warn",
				"useShorthandFunctionType": "error",
				"noUselessElse": "warn",
				"useImportType": "error",
				"useNamingConvention": {
					"level": "warn",
					"options": {
						"strictCase": false,
						"requireAscii": true,
						"conventions": [
							{
								"selector": { "kind": "variable" },
								"formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
							},
							{
								"selector": { "kind": "function" },
								"formats": ["camelCase", "PascalCase"]
							},
							{
								"selector": { "kind": "typeLike" },
								"formats": ["PascalCase"]
							}
						]
					}
				}
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noConsole": {
					"level": "error",
					"options": {
						"allow": ["info", "warn", "error"]
					}
				},
				"noArrayIndexKey": "off"
			},
			"complexity": {
				"noBannedTypes": "warn",
				"noForEach": "off"
			},
			"a11y": {
				"useKeyWithClickEvents": "off",
				"useButtonType": "warn",
				"noStaticElementInteractions": "off",
				"noLabelWithoutControl": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["packages/common/**/*.ts", "packages/common/**/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": [
											"@beak/ui",
											"@beak/ui/**",
											"@beak/state",
											"@beak/state/**",
											"@getbeak/extension-sdk",
											"@getbeak/extension-sdk/**"
										],
										"message": "@beak/common must not depend on higher-layer packages."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["packages/extension-sdk/**/*.ts", "packages/extension-sdk/**/*.tsx", "packages/extension-sdk/**/*.d.ts"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@beak/ui", "@beak/ui/**", "@beak/state", "@beak/state/**", "@beak/common", "@beak/common/**"],
										"message": "@getbeak/extension-sdk is the public extension SDK — keep its dependency surface tiny. No imports from @beak/state, @beak/ui, or @beak/common."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["packages/state/**/*.ts", "packages/state/**/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@beak/ui", "@beak/ui/**", "@getbeak/extension-sdk", "@getbeak/extension-sdk/**"],
										"message": "@beak/state must not depend on @beak/ui or @getbeak/extension-sdk."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["**/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"useImportType": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		}
	]
}
